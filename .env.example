# === Groq API (Required - free at console.groq.com) ===
GROQ_API_KEY=your_groq_api_key_here

# === Security & Authentication (Required in Production) ===
SECRET_KEY=generate_a_long_random_secret_here
JWT_SECRET_KEY=generate_a_long_random_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# === Database Integration (Optional for local dev, defaults to SQLite) ===
# For Neon / PostgreSQL database connection:
DATABASE_URL=postgresql://user:password@host-domain.neon.tech/dbname?sslmode=require

# === Email Delivery (Optional - skip to disable email) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=20

